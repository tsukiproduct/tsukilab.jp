var PW="56109";
var gate=document.getElementById("gate"),app=document.getElementById("app");
var pw=document.getElementById("pw"),err=document.getElementById("err"),btn=document.getElementById("enter");
function tryEnter(){
  if(pw.value.trim()===PW){app.classList.remove("hidden");gate.classList.add("hidden");window.scrollTo(0,0);renderScript();}
  else{err.classList.add("show");pw.value="";pw.focus();}
}
btn.addEventListener("click",tryEnter);
pw.addEventListener("keydown",function(e){if(e.key==="Enter"){e.preventDefault();tryEnter();}});
pw.addEventListener("input",function(){err.classList.remove("show");});
pw.focus();

// タブ切替
var tabs=document.querySelectorAll(".tab");
var panels=document.querySelectorAll(".panel");
tabs.forEach(function(t){
  t.addEventListener("click",function(){
    tabs.forEach(function(x){x.classList.remove("on");});
    panels.forEach(function(x){x.classList.remove("on");});
    t.classList.add("on");
    document.querySelector('.panel[data-panel="'+t.dataset.p+'"]').classList.add("on");
    window.scrollTo(0,0);
  });
});

// 脚本レンダリング
function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");}
function renderScript(){
  var b=document.getElementById("readerBody");
  if(b.dataset.done) return;
  var html='<div class="reader-hero"><div class="case">脚本案 A</div><h1>1世紀旅行記</h1><div class="tagline">一世紀を越えて、アニメの世界へ</div></div>';
  SCRIPT_A.forEach(function(it){
    if(it.type==="scene"){
      html+='<div class="scene-head"><span class="sn">'+esc(it.n)+'</span><span class="rule"></span></div>';
      if(it.body&&it.body.trim()) html+='<div class="scene-body">'+esc(it.body)+'</div>';
    }else if(it.type==="line"){
      html+='<div class="line"><span class="who">'+esc(it.who)+'</span><span class="says">'+esc(it.text)+'</span></div>';
    }else if(it.type==="narration"){
      html+='<div class="narration">'+esc(it.text)+'</div>';
    }else if(it.type==="end"){
      html+='<div class="end-mark">'+esc(it.text)+'</div>';
    }
  });
  b.innerHTML=html; b.dataset.done="1";
}

